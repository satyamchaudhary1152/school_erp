<div class="container mt-5">

    <!-- Heading -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold">
                My Students
            </h1>

            <p class="text-muted mb-0">
                Manage only students assigned to your class.
            </p>

        </div>

        <a href="/teacher/students/add" class="btn btn-success">

            <i class="fa-solid fa-plus"></i>

            Add Student

        </a>

    </div>

    <!-- Dashboard Cards -->
    <div class="row g-4 mb-5">

        <div class="col-lg-4 col-md-6">

            <div class="dashboard-card">

                <div class="icon">👨‍🎓</div>

                <h6>Total Students</h6>

                <h2><%= totalStudents %></h2>

            </div>

        </div>

        <div class="col-lg-4 col-md-6">

            <div class="dashboard-card">

                <div class="icon">🔍</div>

                <h6>Search Results</h6>

                <h2><%= totalResults %></h2>

            </div>

        </div>

        <div class="col-lg-4 col-md-12">

            <div class="dashboard-card">

                <div class="icon">📄</div>

                <h6>Current Page</h6>

                <h2><%= page %></h2>

            </div>

        </div>

    </div>

    <!-- Search -->
    <form
        action="/teacher/students"
        method="GET"
        class="mb-4">

        <div class="input-group">

            <input
                type="text"
                name="search"
                class="form-control"
                placeholder="Search Student..."
                value="<%= search || '' %>">

            <button class="btn btn-primary">

                <i class="fa-solid fa-magnifying-glass"></i>

                Search

            </button>

        </div>

    </form>

    <!-- Table -->

    <table class="table table-striped table-hover table-bordered align-middle">

        <thead>

            <tr>

                <th class="table-dark">Name</th>

                <th class="table-dark">Email</th>

                <th class="table-dark">Class</th>

                <th class="table-dark">Section</th>

                <th class="table-dark">Age</th>

                <th class="table-dark text-center">Edit</th>

                <th class="table-dark text-center">Delete</th>

            </tr>

        </thead>

        <tbody>

            <% if(students.length===0){ %>

                <tr>

                    <td
                        colspan="7"
                        class="text-center text-muted">

                        No students found.

                    </td>

                </tr>

            <% } %>

            <% students.forEach(student=>{ %>

                <tr>

                    <td>

                        <%= student.name %>

                    </td>

                    <td>

                        <%= student.email %>

                    </td>

                    <td>

                        <%= student.class?.className %>

                    </td>

                    <td>

                        <%= student.section?.sectionName %>

                    </td>

                    <td class="text-center">

                        <%= student.age %>

                    </td>

                    <td class="text-center">

                        <a
                            href="/teacher/students/edit/<%= student._id %>"
                            class="btn btn-warning btn-sm">

                            Edit

                        </a>

                    </td>

                    <td class="text-center">

                        <form
                            action="/teacher/students/<%= student._id %>?_method=DELETE"
                            method="POST"
                            style="display:inline"
                            onsubmit="return confirm('Are you sure you want to delete this student?')">

                            <button
                                class="btn btn-danger btn-sm">

                                Delete

                            </button>

                        </form>

                    </td>

                </tr>

            <% }) %>

        </tbody>

    </table>

    <!-- Pagination -->

    <div class="d-flex justify-content-center mt-4">

        <% if(page>1){ %>

            <a
                href="/teacher/students?page=<%= page-1 %>&search=<%= search || '' %>"
                class="btn btn-secondary me-2">

                Previous

            </a>

        <% } %>

        <% for(let i=1;i<=totalPages;i++){ %>

            <a
                href="/teacher/students?page=<%= i %>&search=<%= search || '' %>"
                class="btn <%= page===i ? 'btn-primary':'btn-outline-primary' %> me-2">

                <%= i %>

            </a>

        <% } %>

        <% if(page<totalPages){ %>

            <a
                href="/teacher/students?page=<%= page+1 %>&search=<%= search || '' %>"
                class="btn btn-secondary">

                Next

            </a>

        <% } %>

    </div>

</div>