<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="fw-bold">

                Edit Profile

            </h2>

            <p class="text-muted mb-0">

                Update your personal information.

            </p>

        </div>

        <a
            href="/teacher/profile"
            class="btn btn-secondary">

            <i class="fa-solid fa-arrow-left"></i>

            Back

        </a>

    </div>

    <% if(typeof errors !== "undefined" && errors.length > 0){ %>

        <div class="alert alert-danger">

            <ul class="mb-0">

                <% errors.forEach(error=>{ %>

                    <li>

                        <%= error %>

                    </li>

                <% }) %>

            </ul>

        </div>

    <% } %>

    <div class="card shadow border-0">

        <div class="card-body">

            <form
                action="/teacher/profile?_method=PUT"
                method="POST">

                <div class="row">

                    <!-- Name -->

                    <div class="col-md-6 mb-3">

                        <label class="form-label">

                            Name

                        </label>

                        <input
                            type="text"
                            name="name"
                            class="form-control"
                            value="<%= teacher.name %>"
                            required>

                    </div>

                    <!-- Phone -->

                    <div class="col-md-6 mb-3">

                        <label class="form-label">

                            Phone

                        </label>

                        <input
                            type="text"
                            name="phone"
                            class="form-control"
                            value="<%= teacher.phone %>"
                            required>

                    </div>

                    <!-- Qualification -->

                    <div class="col-md-6 mb-3">

                        <label class="form-label">

                            Qualification

                        </label>

                        <input
                            type="text"
                            name="qualification"
                            class="form-control"
                            value="<%= teacher.qualification %>"
                            required>

                    </div>

                    <!-- Experience -->

                    <div class="col-md-6 mb-3">

                        <label class="form-label">

                            Experience (Years)

                        </label>

                        <input
                            type="number"
                            name="experience"
                            class="form-control"
                            value="<%= teacher.experience %>"
                            required>

                    </div>

                    <!-- Read Only Fields -->

                    <div class="col-md-6 mb-3">

                        <label class="form-label">

                            Employee ID

                        </label>

                        <input
                            type="text"
                            class="form-control"
                            value="<%= teacher.employeeId %>"
                            readonly>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">

                            Email

                        </label>

                        <input
                            type="email"
                            name="email"
                            class="form-control"
                            value="<%= teacher.email %>"
                            required>

                    </div>

                    <!-- Gender -->

<div class="col-md-6 mb-3">

    <label class="form-label">

        Gender

    </label>

    <select
        name="gender"
        class="form-select"
        required>

        <option value="">

            Select Gender

        </option>

        <option
            value="Male"
            <%= teacher.gender === "Male" ? "selected" : "" %>>

            Male

        </option>

        <option
            value="Female"
            <%= teacher.gender === "Female" ? "selected" : "" %>>

            Female

        </option>

        <option
            value="Other"
            <%= teacher.gender === "Other" ? "selected" : "" %>>

            Other

        </option>

    </select>

</div>

                    <div class="col-md-6 mb-3">

                        <label class="form-label">

                            Joining Date

                        </label>

                        <input
    type="date"
    name="joiningDate"
    class="form-control"
    value="<%= teacher.joiningDate.toISOString().split('T')[0] %>">

                    </div>

                </div>

                <div class="mt-4">

                    <button
                        class="btn btn-primary">

                        <i class="fa-solid fa-floppy-disk"></i>

                        Save Changes

                    </button>

                    <a
                        href="/teacher/profile"
                        class="btn btn-secondary ms-2">

                        Cancel

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>