<div class="container mt-5">

    <!-- Heading -->
    <div class="d-flex justify-content-between align-items-center mb-5">

        <div>
            <h1 class="fw-bold">
                Teacher Management
            </h1>

            <p class="text-muted">
                Manage teachers, search records and perform CRUD operations.
            </p>
        </div>

        <a href="/teachers/add" class="btn btn-success">
            <i class="fa-solid fa-plus"></i>
            Add Teacher
        </a>

    </div>

    <!-- Dashboard Cards -->
    <div class="row g-4 mb-5">

        <!-- Total Teachers -->
        <div class="col-lg-3 col-md-6">
            <div class="dashboard-card">
                <div class="icon">👨‍🏫</div>
                <h6>Total Teachers</h6>
                <h2><%= totalTeachers %></h2>
            </div>
        </div>

        <!-- Active Teachers -->
        <div class="col-lg-3 col-md-6">
            <div class="dashboard-card">
                <div class="icon">✅</div>
                <h6>Active Teachers</h6>
                <h2><%= activeTeachers %></h2>
            </div>
        </div>

        <!-- Search Results -->
        <div class="col-lg-3 col-md-6">
            <div class="dashboard-card">
                <div class="icon">🔍</div>
                <h6>Search Results</h6>
                <h2><%= totalResults %></h2>
            </div>
        </div>

        <!-- Current Page -->
        <div class="col-lg-3 col-md-6">
            <div class="dashboard-card">
                <div class="icon">📄</div>
                <h6>Current Page</h6>
                <h2><%= page %></h2>
            </div>
        </div>

    </div>

    <!-- Search -->
    <form action="/teachers" method="GET" class="mb-4">

        <div class="input-group">

            <input
                type="text"
                name="search"
                class="form-control"
                placeholder="Search Teacher..."
                value="<%= search || '' %>">

            <button class="btn btn-primary">
                <i class="fa-solid fa-magnifying-glass"></i>
                Search
            </button>

        </div>

    </form>

    <!-- Table -->

    <table class="table table-striped table-hover table-bordered align-middle">

        <thead>

            <tr>

                <th>Name</th>
                <th>Email</th>
                <th class="text-center">Experience</th>
                <th class="text-center">Edit</th>
                <th class="text-center">Delete</th>

            </tr>

        </thead>

        <tbody>

        <% if (teachers.length === 0) { %>

            <tr>

                <td colspan="6" class="text-center text-muted py-4">

                    No teachers found.

                </td>

            </tr>

        <% } else { %>

            <% teachers.forEach(teacher => { %>

                <tr>

                    <td><%= teacher.name %></td>

                    <td><%= teacher.email %></td>

                    <td class="text-center">
                        <%= teacher.experience %> Years
                    </td>

                    <td class="text-center">

                        <a
                            href="/teachers/<%= teacher._id %>/edit"
                            class="btn btn-warning btn-sm">

                            Edit

                        </a>

                    </td>

                    <td class="text-center">

                        <form
                            action="/teachers/<%= teacher._id %>?_method=DELETE"
                            method="POST"
                            style="display:inline;"
                            onsubmit="return confirm('Are you sure you want to delete this teacher?')">

                            <button class="btn btn-danger btn-sm">

                                Delete

                            </button>

                        </form>

                    </td>

                </tr>

            <% }) %>

        <% } %>

        </tbody>

    </table>

    <!-- Pagination -->

    <div class="d-flex justify-content-center mt-4">

        <% if(page > 1){ %>

            <a
                href="/teachers?page=<%= page-1 %>&search=<%= search || '' %>"
                class="btn btn-secondary me-2">

                Previous

            </a>

        <% } %>

        <% for(let i = 1; i <= totalPages; i++){ %>

            <a
                href="/teachers?page=<%= i %>&search=<%= search || '' %>"
                class="btn <%= page === i ? 'btn-primary' : 'btn-outline-primary' %> me-2">

                <%= i %>

            </a>

        <% } %>

        <% if(page < totalPages){ %>

            <a
                href="/teachers?page=<%= page+1 %>&search=<%= search || '' %>"
                class="btn btn-secondary">

                Next

            </a>

        <% } %>

    </div>

</div>