<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>School ERP</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
        rel="stylesheet">

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <link
        rel="stylesheet"
        href="/css/loginSelection.css">

</head>

<body>

<div class="background">

    <span class="blob blob1"></span>

    <span class="blob blob2"></span>

    <span class="blob blob3"></span>

</div>

<div class="container login-wrapper">

    <div class="text-center mb-5">

        <div class="logo-circle">

            <i class="fa-solid fa-school"></i>

        </div>

        <h1 class="mt-4 fw-bold text-white">

            School ERP

        </h1>

        <p class="text-light opacity-75">

            Smart • Secure • Modern School Attendance System

        </p>

    </div>

    <div class="row justify-content-center g-5">

        <!-- Admin -->

        <div class="col-lg-4 col-md-6">

            <div class="glass-card">

                <div class="icon admin">

                    <i class="fa-solid fa-user-shield"></i>

                </div>

                <h3>

                    Administrator

                </h3>

                <p>

                    Manage teachers, students, reports,
                    attendance and complete ERP.

                </p>

                <a
                    href="/login/admin"
                    class="btn btn-login">

                    Login as Admin

                </a>

            </div>

        </div>

        <!-- Teacher -->

        <div class="col-lg-4 col-md-6">

            <div class="glass-card">

                <div class="icon teacher">

                    <i class="fa-solid fa-chalkboard-user"></i>

                </div>

                <h3>

                    Teacher

                </h3>

                <p>

                    Take attendance, manage your class,
                    update profile and reports.

                </p>

                <a
                    href="/login/teacher"
                    class="btn btn-login">

                    Login as Teacher

                </a>

            </div>

        </div>

    </div>

</div>

<footer>

    © 2026 School ERP • Built By Satyam Chaudhary • and Omkar Tripathi

</footer>

</body>

</html>