<div class="container-fluid">

    <div class="row justify-content-center">

        <div class="col-lg-10">

            <div class="card shadow border-0 rounded-4">

                <div class="card-header bg-primary text-white py-3">

                    <h3 class="mb-0">

                        <i class="fa-solid fa-user-shield me-2"></i>

                        My Profile

                    </h3>

                </div>

                <div class="card-body p-5">

                    <div class="row">

                        <!-- Left -->

                        <div class="col-md-4 text-center">

                            <div class="mb-4">

                                <i class="fa-solid fa-user-circle text-primary"
                                   style="font-size:130px;"></i>

                            </div>

                            <h3>

                                <%= admin.name %>

                            </h3>

                            <p class="text-muted">

                                Administrator

                            </p>

                        </div>

                        <!-- Right -->

                        <div class="col-md-8">

                            <table class="table table-bordered">

                                <tbody>

                                    <tr>

                                        <th width="30%">

                                            Name

                                        </th>

                                        <td>

                                            <%= admin.name %>

                                        </td>

                                    </tr>

                                    <tr>

                                        <th>

                                            Email

                                        </th>

                                        <td>

                                            <%= admin.email %>

                                        </td>

                                    </tr>

                                    <tr>

                                        <th>

                                            Mobile

                                        </th>

                                        <td>

                                            <%= admin.mobile || "-" %>

                                        </td>

                                    </tr>

                                    <tr>

                                        <th>

                                            Gender

                                        </th>

                                        <td>

                                            <%= admin.gender || "-" %>

                                        </td>

                                    </tr>

                                    <tr>

                                        <th>

                                            Role

                                        </th>

                                        <td>

                                            Administrator

                                        </td>

                                    </tr>

                                </tbody>

                            </table>

                            <div class="mt-4 d-flex gap-3">

                                <a href="/dashboard/profile/edit"
                                   class="btn btn-primary">

                                    <i class="fa-solid fa-user-pen me-2"></i>

                                    Edit Profile

                                </a>

                                <a href="/dashboard/change-password"
                                   class="btn btn-warning">

                                    <i class="fa-solid fa-key me-2"></i>

                                    Change Password

                                </a>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>