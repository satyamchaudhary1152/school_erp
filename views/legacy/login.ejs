<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>Admin Login</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
        rel="stylesheet">

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <style>

        body{

            height:100vh;

            display:flex;

            justify-content:center;

            align-items:center;

            background:linear-gradient(135deg,#0d6efd,#6610f2);

            font-family:Segoe UI,Tahoma,Geneva,Verdana,sans-serif;

        }

        .login-card{

            width:420px;

            border:none;

            border-radius:20px;

            padding:35px;

            background:white;

            box-shadow:0 20px 50px rgba(0,0,0,.2);

        }

        .logo{

            width:90px;

            height:90px;

            background:#0d6efd;

            color:white;

            border-radius:50%;

            display:flex;

            justify-content:center;

            align-items:center;

            margin:auto;

            font-size:38px;

        }

        .btn-login{

            width:100%;

            padding:12px;

            font-size:17px;

            border-radius:10px;

        }

        .form-control{

            height:48px;

        }

    </style>

</head>

<body>

<div class="login-card">

    <div class="text-center mb-4">

        <div class="logo">

            <i class="fa-solid fa-user-shield"></i>

        </div>

        <h2 class="mt-3 fw-bold">

            School ERP

        </h2>

        <p class="text-muted">

            Administrator Login

        </p>

    </div>
    
    <% if(error){ %>

        <div class="alert alert-danger">

            <%= error %>

        </div>

    <% } %>

    <form action="/login" method="POST">

        <div class="mb-3">

            <label class="form-label">

                Email

            </label>

            <input

                type="email"

                name="email"

                class="form-control"

                placeholder="Enter Email"

                required>

        </div>

        <div class="mb-4">

            <label class="form-label">

                Password

            </label>

            <input

                type="password"

                name="password"

                class="form-control"

                placeholder="Enter Password"

                required>

        </div>

        <button class="btn btn-primary btn-login">

            <i class="fa-solid fa-right-to-bracket"></i>

            Login

        </button>

    </form>

</div>

</body>

</html>