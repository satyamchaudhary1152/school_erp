

<div class="container mt-5">

<!-- Heading -->

<div class="d-flex justify-content-between align-items-center mb-5">

    <div>

        <h1 class="fw-bold">

            Teacher Assignment

        </h1>

        <p class="text-muted mb-0">

            Manage Teacher-Class-Section-Subject Assignments.

        </p>

    </div>

    <a
        href="/teacher-assignments/add"
        class="btn btn-success">

        <i class="fa-solid fa-plus"></i>

        Assign Teacher

    </a>

</div>

    <!-- Dashboard Cards -->

    <div class="row g-4 mb-5">

        <!-- Total -->

        <div class="col-lg-4 col-md-6">

            <div class="dashboard-card">

                <div class="icon">
                    👨‍🏫
                </div>

                <h6>Total Assignments</h6>

                <h2>

                    <%= totalAssignments %>

                </h2>

            </div>

        </div>

        <!-- Active -->

        <div class="col-lg-4 col-md-6">

            <div class="dashboard-card">

                <div class="icon">
                    ✅
                </div>

                <h6>Active Assignments</h6>

                <h2>

                    <%= activeAssignments %>

                </h2>

            </div>

        </div>

        <!-- Search -->

        <div class="col-lg-4 col-md-6">

            <div class="dashboard-card">

                <div class="icon">
                    🔍
                </div>

                <h6>Search Results</h6>

                <h2>

                    <%= totalResults %>

                </h2>

            </div>

        </div>

    </div>

    <!-- Search -->

    <form
        action="/teacher-assignments"
        method="GET"
        class="mb-4">

        <div class="input-group">

            <input
                type="text"
                class="form-control"
                name="search"
                placeholder="Search by Teacher, Class, Section or Subject..."
                value="<%= search || '' %>">

            <button
                class="btn btn-primary">

                🔍 Search

            </button>

        </div>

    </form>

    <!-- Table -->

    <div class="table-responsive">

        <table class="table table-striped table-hover table-bordered align-middle">

            <thead>

                <tr>

                    <th class="table-dark">

                        Teacher

                    </th>

                    <th class="table-dark">

                        Class

                    </th>

                    <th class="table-dark">

                        Section

                    </th>

                    <th class="table-dark">

                        Subject

                    </th>

                    <th class="table-dark">
                        Role
                    </th>

                    <th class="table-dark text-center">

                        Status

                    </th>

                    <th class="table-dark text-center">

                        Edit

                    </th>

                    <th class="table-dark text-center">

                        Delete

                    </th>

                </tr>

            </thead>

            <tbody>

                <% if(assignments.length===0){ %>

                    <tr>

                        <td
                            colspan="7"
                            class="text-center py-4 text-muted">

                            No Assignment Found.

                        </td>

                    </tr>

                <% } %>

                <% assignments.forEach(assignment=>{ %>

                    <tr>

                        <td>

                            <%= assignment.teacher ? assignment.teacher.name : "Teacher Deleted" %>

                        </td>

                        <td>

                            <%= assignment.class ? assignment.class.className : "-" %>

                        </td>

                        <td>

                            <%= assignment.section ? assignment.section.sectionName : "-" %>

                        </td>

                        <td>

                            <%= assignment.subject ? assignment.subject.subjectName : "-" %>

                        </td>

                        <td>

    <% if(assignment.role==="Class Teacher"){ %>

        <span class="badge bg-primary">

            Class Teacher

        </span>

    <% }else{ %>

        <span class="badge bg-secondary">

            Subject Teacher

        </span>

    <% } %>

</td>

                        <td class="text-center">

                            <% if(assignment.status==="Active"){ %>

                                <span class="badge bg-success">

                                    Active

                                </span>

                            <% }else{ %>

                                <span class="badge bg-danger">

                                    Inactive

                                </span>

                            <% } %>

                        </td>

                        <td class="text-center">

                            <a
                                href="/teacher-assignments/<%= assignment._id %>/edit"
                                class="btn btn-warning btn-sm">

                                Edit

                            </a>

                        </td>

                        <td class="text-center">

                            <form
                                action="/teacher-assignments/<%= assignment._id %>?_method=DELETE"
                                method="POST"
                                style="display:inline;"
                                onsubmit="return confirm('Delete this Assignment?')">

                                <button
                                    class="btn btn-danger btn-sm">

                                    Delete

                                </button>

                            </form>

                        </td>

                    </tr>

                <% }) %>

            </tbody>

        </table>

    </div>

    <!-- Pagination -->

    <div class="d-flex justify-content-center mt-4">

        <% if(page>1){ %>

            <a
                href="/teacher-assignments?page=<%= page-1 %>&search=<%= search %>"
                class="btn btn-secondary me-2">

                Previous

            </a>

        <% } %>

        <% for(let i=1;i<=totalPages;i++){ %>

            <a
                href="/teacher-assignments?page=<%= i %>&search=<%= search %>"
                class="btn <%= page===i ? 'btn-primary' : 'btn-outline-primary' %> me-2">

                <%= i %>

            </a>

        <% } %>

        <% if(page<totalPages){ %>

            <a
                href="/teacher-assignments?page=<%= page+1 %>&search=<%= search %>"
                class="btn btn-secondary">

                Next

            </a>

        <% } %>

    </div>

</div>

