

<div class="container mt-5">

    <div class="card shadow-lg border-0">

        <div class="card-header bg-success text-white">

            <h3 class="mb-0">

                Assign Teacher

            </h3>

        </div>

        <div class="card-body">

            <form action="/teacher-assignments" method="POST">

                <% if(typeof customError !== "undefined"){ %>

                    <div class="alert alert-danger">

                        <%= customError %>

                    </div>

                <% } %>

                <!-- Teacher -->

                <div class="mb-3">

                    <label class="form-label">

                        Teacher

                    </label>

                    <select
                        name="teacher"
                        class="form-select"
                        required>

                        <option value="">

                            Select Teacher

                        </option>

                        <% teachers.forEach(teacher=>{ %>

                            <option
                                value="<%= teacher._id %>"

                                <%= assignment.teacher==teacher._id.toString() ? "selected" : "" %>>

                                <%= teacher.name %>

                            </option>

                        <% }) %>

                    </select>

                    <% if(errors.teacher){ %>

                        <div class="text-danger">

                            <%= errors.teacher.message %>

                        </div>

                    <% } %>

                </div>



                <!-- Class -->

                <div class="mb-3">

                    <label class="form-label">

                        Class

                    </label>

                    <select
                        id="classSelect"
                        name="class"
                        class="form-select"
                        required>

                        <option value="">

                            Select Class

                        </option>

                        <% classes.forEach(cls=>{ %>

                            <option
                                value="<%= cls._id %>"

                                <%= assignment.class==cls._id.toString() ? "selected" : "" %>>

                                <%= cls.className %>

                            </option>

                        <% }) %>

                    </select>

                    <% if(errors.class){ %>

                        <div class="text-danger">

                            <%= errors.class.message %>

                        </div>

                    <% } %>

                </div>



                <!-- Section -->

                <div class="mb-3">

                    <label class="form-label">

                        Section

                    </label>

                    <select
                        id="sectionSelect"
                        name="section"
                        class="form-select"
                        required>

                        <option value="">

                            Select Section

                        </option>

                        <% sections.forEach(section=>{ %>

                            <option

                                value="<%= section._id %>"

                                data-class="<%= section.class._id %>"

                                <%= assignment.section==section._id.toString() ? "selected" : "" %>>

                                <%= section.sectionName %>

                            </option>

                        <% }) %>

                    </select>

                    <% if(errors.section){ %>

                        <div class="text-danger">

                            <%= errors.section.message %>

                        </div>

                    <% } %>

                </div>



                <!-- Subject -->

                <div class="mb-4">

                    <label class="form-label">

                        Subject

                    </label>

                    <select
                        name="subject"
                        class="form-select"
                        required>

                        <option value="">

                            Select Subject

                        </option>

                        <% subjects.forEach(subject=>{ %>

                            <option
                                value="<%= subject._id %>"

                                <%= assignment.subject==subject._id.toString() ? "selected" : "" %>>

                                <%= subject.subjectName %>

                            </option>

                        <% }) %>

                    </select>

                    <% if(errors.subject){ %>

                        <div class="text-danger">

                            <%= errors.subject.message %>

                        </div>

                    <% } %>

                </div>

                <!-- Role -->

<div class="mb-3">

    <label class="form-label">

        Role

    </label>

    <select
        name="role"
        class="form-select"
        required>

        <option value="Subject Teacher">

            Subject Teacher

        </option>

        <option value="Class Teacher">

            Class Teacher

        </option>

    </select>

</div>



                <!-- Status -->

                <div class="mb-4">

                    <label class="form-label">

                        Status

                    </label>

                    <select
                        name="status"
                        class="form-select">

                        <option
                            value="Active"
                            <%= assignment.status=="Active" ? "selected" : "" %>>

                            Active

                        </option>

                        <option
                            value="Inactive"
                            <%= assignment.status=="Inactive" ? "selected" : "" %>>

                            Inactive

                        </option>

                    </select>

                </div>



                <!-- Buttons -->

                <div class="d-flex justify-content-between">

                    <a
                        href="/teacher-assignments"
                        class="btn btn-secondary">

                        ← Back

                    </a>

                    <button
                        class="btn btn-success">

                        💾 Assign Teacher

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

<script>

const classSelect=document.getElementById("classSelect");

const sectionSelect=document.getElementById("sectionSelect");

function filterSections(){

    const classId=classSelect.value;

    Array.from(sectionSelect.options).forEach(option=>{

        if(option.value==="") return;

        option.style.display=

        option.dataset.class===classId

        ? "block"

        : "none";

    });

    sectionSelect.value="";
}

classSelect.addEventListener("change",filterSections);

window.onload=filterSections;

</script>

