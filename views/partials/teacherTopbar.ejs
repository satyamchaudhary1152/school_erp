<div class="topbar">

    <div class="d-flex justify-content-between align-items-center w-100">

        <!-- Left -->

        <div>

            <h4 class="fw-bold mb-0">

                <%= title %>

            </h4>

        </div>

        <!-- Right -->

        <div class="dropdown">

            <button
                class="btn btn-light border shadow-sm dropdown-toggle d-flex align-items-center"
                type="button"
                data-bs-toggle="dropdown"
                aria-expanded="false">

                <i class="fa-solid fa-user-circle me-2 fs-5"></i>

                <div class="text-start">

                    <div class="fw-semibold">

                        <%= teacher ? teacher.name : "Teacher" %>

                    </div>

                    <small class="text-muted">

                        <%= teacher ? teacher.email : "" %>

                    </small>

                </div>

            </button>

            <ul class="dropdown-menu dropdown-menu-end shadow">

    <li>

        <a class="dropdown-item" href="/teacher/profile">

            <i class="fa-solid fa-user me-2"></i>

            My Profile

        </a>

    </li>

    <li>

        <a class="dropdown-item" href="/teacher/profile/edit">

            <i class="fa-solid fa-pen me-2"></i>

            Edit Profile

        </a>

    </li>

    <li>

        <a class="dropdown-item" href="/teacher/change-password">

            <i class="fa-solid fa-key me-2"></i>

            Change Password

        </a>

    </li>

    <li><hr class="dropdown-divider"></li>

    <li>

        <a class="dropdown-item text-danger" href="/logout">

            <i class="fa-solid fa-right-from-bracket me-2"></i>

            Logout

        </a>

    </li>

</ul>

        </div>

    </div>

</div>