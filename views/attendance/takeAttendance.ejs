<form action="/attendance/take" method="GET">

<div class="card shadow-sm border-0">

<div class="card-body">

<div class="row g-4">

<!-- Section -->

<div class="col-md-6">

<label class="form-label">

Section

</label>

<select
name="section"
class="form-select"
required>

<option value="">

Select Section

</option>

<% sections.forEach(section=>{ %>

<option

value="<%= section._id %>"

<%= selectedSection==section._id.toString() ? "selected" : "" %>>

<%= section.class.className %> - <%= section.sectionName %>

</option>

<% }) %>

</select>

</div>

<!-- Date -->

<div class="col-md-6">

<label class="form-label">

Attendance Date

</label>

<input

type="date"

name="date"

class="form-control"

value="<%= selectedDate %>"

required>

</div>

</div>

<div class="mt-4">

<button class="btn btn-success">

<i class="fa-solid fa-users"></i>

Load Students

</button>

</div>

</div>

</div>

</form>

<% if (students && students.length > 0) { %>

<form action="/attendance" method="POST">

    <input
        type="hidden"
        name="section"
        value="<%= selectedSection %>">

    <input
        type="hidden"
        name="date"
        value="<%= selectedDate %>">

    <div class="card shadow-sm border-0 mt-4">

        <div class="card-header bg-primary text-white">

            <h5 class="mb-0">

                Student Attendance

            </h5>

        </div>

        <div class="card-body p-0">

            <table class="table table-bordered table-hover mb-0">

                <thead class="table-light">

                    <tr>

                        <th style="width:80px;">#</th>

                        <th>Student Name</th>

                        <th style="width:220px;">Attendance</th>

                    </tr>

                </thead>

                <tbody>

                    <% students.forEach((student,index)=>{ %>

                    <tr>

                        <td>

                            <%= index+1 %>

                        </td>

                        <td>

                            <%= student.name %>

                        </td>

                        <td>

                            <input
                                type="hidden"
                                name="students[<%= index %>][student]"
                                value="<%= student._id %>">

                            <select
                                name="students[<%= index %>][status]"
                                class="form-select">

                                <option value="Present">

                                    Present

                                </option>

                                <option value="Absent">

                                    Absent

                                </option>

                                <option value="Late">

                                    Late

                                </option>

                                <option value="Leave">

                                    Leave

                                </option>

                            </select>

                        </td>

                    </tr>

                    <% }) %>

                </tbody>

            </table>

        </div>

    </div>

    <div class="mt-4">

        <button class="btn btn-success">

            <i class="fa-solid fa-floppy-disk"></i>

            Save Attendance

        </button>

    </div>

</form>

<% } %>