<div class="container-fluid">

    <!-- Heading -->

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold">
                Edit Attendance
            </h1>

            <p class="text-muted">
                Update student attendance record.
            </p>

        </div>

        <a href="/attendance" class="btn btn-secondary">

            <i class="fa-solid fa-arrow-left"></i>

            Back

        </a>

    </div>


    <div class="card shadow-sm border-0">

        <div class="card-body">

            <form action="/attendance/<%= attendance._id %>?_method=PUT" method="POST">

                <div class="row mb-4">

                    <div class="col-md-4">

                        <label class="form-label">

                            Date

                        </label>

                        <input
                            type="text"
                            class="form-control"
                            value="<%= new Date(attendance.date).toLocaleDateString() %>"
                            readonly>

                    </div>

                    <div class="col-md-4">

                        <label class="form-label">

                            Class

                        </label>

                        <input
                            type="text"
                            class="form-control"
                            value="<%= attendance.class.className %>"
                            readonly>

                    </div>

                    <div class="col-md-4">

                        <label class="form-label">

                            Section

                        </label>

                        <input
                            type="text"
                            class="form-control"
                            value="<%= attendance.section.sectionName %>"
                            readonly>

                    </div>

                </div>


                <div class="table-responsive">

                    <table class="table table-bordered table-hover align-middle">

                        <thead class="table-dark">

                            <tr>

                                <th style="width:80px;">

                                    #

                                </th>

                                <th>

                                    Student Name

                                </th>

                                <th style="width:220px;">

                                    Attendance

                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            <% attendance.students.forEach((item,index)=>{ %>

                                <tr>

                                    <td>

                                        <%= index+1 %>

                                    </td>

                                    <td>

                                        <%= item.student.name %>

                                    </td>

                                    <td>

                                        <input
                                            type="hidden"
                                            name="students[<%= index %>][student]"
                                            value="<%= item.student._id %>">

                                        <select
                                            name="students[<%= index %>][status]"
                                            class="form-select">

                                            <option
                                                value="Present"
                                                <%= item.status==="Present" ? "selected" : "" %>>

                                                Present

                                            </option>

                                            <option
                                                value="Absent"
                                                <%= item.status==="Absent" ? "selected" : "" %>>

                                                Absent

                                            </option>

                                            <option
                                                value="Late"
                                                <%= item.status==="Late" ? "selected" : "" %>>

                                                Late

                                            </option>

                                            <option
                                                value="Leave"
                                                <%= item.status==="Leave" ? "selected" : "" %>>

                                                Leave

                                            </option>

                                        </select>

                                    </td>

                                </tr>

                            <% }) %>

                        </tbody>

                    </table>

                </div>


                <div class="mt-4">

                    <button class="btn btn-primary">

                        <i class="fa-solid fa-floppy-disk"></i>

                        Update Attendance

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>