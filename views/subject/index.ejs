

<div class="container mt-5">

<!-- Heading -->
<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h1 class="fw-bold">
            Subject Management
        </h1>

        <p class="text-muted mb-0">
            Manage Subjects, search records and perform CRUD operations.
        </p>
    </div>

    <a href="/subjects/add" class="btn btn-success">
        <i class="fa-solid fa-plus"></i>
        Add Subejct
    </a>

</div>

    <!-- Dashboard Cards -->

    <div class="row g-4 mb-5">

        <!-- Total Subjects -->

        <div class="col-lg-4 col-md-6">

            <div class="dashboard-card">

                <div class="icon">
                    📚
                </div>

                <h6>Total Subjects</h6>

                <h2>
                    <%= totalSubjects %>
                </h2>

            </div>

        </div>

        <!-- Active Subjects -->

        <div class="col-lg-4 col-md-6">

            <div class="dashboard-card">

                <div class="icon">
                    ✅
                </div>

                <h6>Active Subjects</h6>

                <h2>
                    <%= activeSubjects %>
                </h2>

            </div>

        </div>

        <!-- Search Results -->

        <div class="col-lg-4 col-md-12">

            <div class="dashboard-card">

                <div class="icon">
                    🔍
                </div>

                <h6>Search Results</h6>

                <h2>
                    <%= totalResults %>
                </h2>

            </div>

        </div>

    </div>

    <!-- Search -->

    <form
        action="/subjects"
        method="GET"
        class="mb-4">

        <div class="input-group">

            <input
                type="text"
                name="search"
                class="form-control"
                placeholder="Search by Subject Name or Subject Code..."
                value="<%= search || '' %>">

            <button class="btn btn-primary">

                🔍 Search

            </button>

        </div>

    </form>

    <!-- Subject Table -->

    <div class="table-responsive">

        <table class="table table-striped table-hover table-bordered align-middle">

            <thead>

                <tr>

                    <th class="table-dark">
                        Subject Name
                    </th>

                    <th class="table-dark">
                        Subject Code
                    </th>

                    <th class="table-dark">
                        Description
                    </th>

                    <th class="table-dark text-center">
                        Status
                    </th>

                    <th class="table-dark text-center">
                        Edit
                    </th>

                    <th class="table-dark text-center">
                        Delete
                    </th>

                </tr>

            </thead>

            <tbody>

                <% if(subjects.length === 0){ %>

                    <tr>

                        <td colspan="6" class="text-center text-muted py-4">

                            No Subjects Found.

                        </td>

                    </tr>

                <% } %>

                <% subjects.forEach(subject => { %>

                    <tr>

                        <td>

                            <strong>

                                <%= subject.subjectName %>

                            </strong>

                        </td>

                        <td>

                            <span class="badge bg-primary">

                                <%= subject.subjectCode %>

                            </span>

                        </td>

                        <td>

                            <%= subject.description || "No Description" %>

                        </td>

                        <td class="text-center">

                            <% if(subject.status === "Active"){ %>

                                <span class="badge bg-success">

                                    Active

                                </span>

                            <% } else { %>

                                <span class="badge bg-danger">

                                    Inactive

                                </span>

                            <% } %>

                        </td>

                        <td class="text-center">

                            <a
                                href="/subjects/<%= subject._id %>/edit"
                                class="btn btn-warning btn-sm">

                                Edit

                            </a>

                        </td>

                        <td class="text-center">

                            <form
                                action="/subjects/<%= subject._id %>?_method=DELETE"
                                method="POST"
                                style="display:inline;"
                                onsubmit="return confirm('Are you sure you want to delete this subject?')">

                                <button
                                    class="btn btn-danger btn-sm">

                                    Delete

                                </button>

                            </form>

                        </td>

                    </tr>

                <% }) %>

            </tbody>

        </table>

    </div>

    <!-- Pagination -->

    <div class="d-flex justify-content-center mt-4">

        <% if(page > 1){ %>

            <a
                href="/subjects?page=<%= page-1 %>&search=<%= search || '' %>"
                class="btn btn-secondary me-2">

                Previous

            </a>

        <% } %>

        <% for(let i=1; i<=totalPages; i++){ %>

            <a
                href="/subjects?page=<%= i %>&search=<%= search || '' %>"
                class="btn <%= page===i ? 'btn-primary' : 'btn-outline-primary' %> me-2">

                <%= i %>

            </a>

        <% } %>

        <% if(page < totalPages){ %>

            <a
                href="/subjects?page=<%= page+1 %>&search=<%= search || '' %>"
                class="btn btn-secondary">

                Next

            </a>

        <% } %>

    </div>

</div>

